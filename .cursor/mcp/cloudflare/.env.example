# Cloudflare credentials — never commit real values
#
# Preferred: Teknovo secret store (outside git)
#   Linux production: /root/.config/teknovo/secrets/cloudflare.env
#   Windows dev:        %USERPROFILE%\.config\teknovo\secrets\cloudflare.env
#
# Optional local override: copy this file to .env (development only)

# cloudflare.env format:
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_ZONE_ID=

# API token scopes (least privilege):
#   Account: Cloudflare Pages (Edit), Account Settings (Read)
#   Zone: DNS (Edit), Zone (Read)

CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=

# Override secret store directory (optional)
# TEKNOVO_SECRETS_DIR=
