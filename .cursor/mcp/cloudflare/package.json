{
  "name": "teknovo-cloudflare-mcp",
  "version": "1.0.0",
  "description": "Teknovo Cloudflare MCP — Pages, DNS, and custom domain automation",
  "type": "module",
  "main": "server.js",
  "bin": {
    "teknovo-cloudflare-mcp": "./server.js"
  },
  "scripts": {
    "start": "node server.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --runInBand",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "lint": "node scripts/lint.js",
    "check": "npm run lint && npm test"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "dotenv": "^16.4.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "collectCoverageFrom": [
      "lib/**/*.js",
      "tools/**/*.js",
      "../shared/**/*.js",
      "!**/node_modules/**",
      "!lib/logger.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 74,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "testPathIgnorePatterns": ["/node_modules/"]
  },
  "keywords": [
    "mcp",
    "cloudflare",
    "pages",
    "dns",
    "teknovo"
  ],
  "license": "MIT"
}
