{
  "name": "@teknovo/orchestrator",
  "version": "1.0.0",
  "description": "Teknovo multi-agent orchestrator — task routing, dispatch, workflow",
  "type": "module",
  "main": "orchestrator.js",
  "bin": {
    "teknovo-orchestrator": "./orchestrator.js"
  },
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "start": "node orchestrator.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "yaml": "^2.7.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "collectCoverageFrom": [
      "orchestrator.js",
      "index.js",
      "!**/node_modules/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "license": "MIT"
}
