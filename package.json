{
  "name": "smk-teknovo-portal",
  "version": "2.0.0",
  "private": true,
  "description": "SMK Teknovo public portal \u2014 immersive Phases 1\u20132 (R3F/GSAP) + static multi-page shell",
  "scripts": {
    "dev": "npm run dev --prefix apps/immersive-portal",
    "build:immersive": "npm run build --prefix apps/immersive-portal",
    "merge:immersive": "node scripts/merge-immersive-build.js",
    "build": "npm run build:immersive && npm run merge:immersive && node scripts/validate.js",
    "lint": "npm run build:immersive",
    "serve": "python3 -m http.server 8080 --directory public",
    "preview": "wrangler dev",
    "deploy": "wrangler deploy"
  },
  "devDependencies": {
    "wrangler": "4.22.0"
  },
  "workspaces": [
    "apps/immersive-portal"
  ]
}
