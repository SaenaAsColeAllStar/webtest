{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "rootDir": ".",
    "outDir": "dist",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": [
    "cli/**/*.ts",
    "commands/**/*.ts",
    "processors/**/*.ts",
    "validators/**/*.ts",
    "reports/**/*.ts",
    "src/**/*.ts",
    "src/**/*.d.ts"
  ]
}
