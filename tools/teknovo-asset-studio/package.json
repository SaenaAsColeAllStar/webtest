{
  "name": "teknovo-asset-studio",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @teknovo-asset-studio/web",
    "build": "npm run build --workspace @teknovo-asset-studio/web",
    "lint": "npm run lint --workspace @teknovo-asset-studio/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "verify:flow": "tsx scripts/verify-flow.ts",
    "db:seed": "tsx scripts/verify-flow.ts --seed"
  },
  "devDependencies": {
    "@types/node": "^24.0.13",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
